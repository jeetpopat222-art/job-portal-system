# Auto detect text files and normalize line endings to LF
* text=auto

# Python files
*.py text eol=lf

# Web files
*.html text eol=lf linguist-generated=true
*.css text eol=lf linguist-generated=true
*.js text eol=lf linguist-generated=true
*.json text eol=lf

# Documentation
*.md text eol=lf
*.txt text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary